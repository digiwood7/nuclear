  <data key="d5">1775523378</data>
  <data key="d6"></data>
</node>
<node id="점선원">
  <data key="d0">점선원</data>
  <data key="d1">artifact</data>
  <data key="d2">점선원은 고유영상왜곡 측정 시 image를 얻기 위해 사용되는 선원이다.</data>
  <data key="d3">chunk-475783fc231bbcff930d8d8bc16de315</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775523378</data>
  <data key="d6"></data>
