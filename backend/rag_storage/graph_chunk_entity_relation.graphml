<node id="신체">
  <data key="d0">신체</data>
  <data key="d1">naturalobject</data>
  <data key="d2">신체 is the object of diagnosis using γ-rays or β-rays.</data>
  <data key="d3">chunk-b06ed9f5e0dd9cd85ffaf0fc38757627</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522906</data>
