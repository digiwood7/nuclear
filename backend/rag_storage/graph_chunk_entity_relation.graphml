<node id="System Resolution">
  <data key="d0">System Resolution</data>
  <data key="d1">concept</data>
  <data key="d2">System Resolution refers to the resolution of the camera system and is measured using a collimator-equipped system with a Four-quadrant bar phantom.</data>
  <data key="d3">chunk-435f46f7df27683a6f082e9ae451704b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775523381</data>
  <data key="d6"></data>
</node>
<node id="Detector 1">
  <data key="d0">Detector 1</data>
  <data key="d1">artifact</data>
  <data key="d2">Detector 1 is one of the detectors used in COR Calibration.&lt;SEP&gt;Detector 1 obtains an image when using the Four-quadrant bar phantom.</data>
  <data key="d3">chunk-435f46f7df27683a6f082e9ae451704b&lt;SEP&gt;chunk-833544a0af4106771fa805c95df67753</data>
