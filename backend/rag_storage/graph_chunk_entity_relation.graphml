  <data key="d2">산란의 한 종류.</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522942</data>
  <data key="d6"></data>
</node>
<node id="흡수">
  <data key="d0">흡수</data>
  <data key="d1">concept</data>
  <data key="d2">방사선과 원자핵의 상호작용으로 일어나는 현상.&lt;SEP&gt;흡수 refers to absorption.</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac&lt;SEP&gt;chunk-c6c70af745f8587837b4afa84c640794</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522975</data>
  <data key="d6"></data>
</node>
<node id="핵반응">
  <data key="d0">핵반응</data>
  <data key="d1">concept</data>
  <data key="d2">방사선과 원자핵의 상호작용으로 일어나는 현상.&lt;SEP&gt;핵반응은 검출 원리 중 하나이다.</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac&lt;SEP&gt;chunk-78dbaba6777799b28327851a2d931cc2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775523173</data>
  <data key="d6"></data>
</node>
<node id="핵변환">
  <data key="d0">핵변환</data>
  <data key="d1">concept</data>
  <data key="d2">방사선과 원자핵의 상호작용으로 일어나는 현상.</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522942</data>
  <data key="d6"></data>
</node>
<node id="제동방사">
  <data key="d0">제동방사</data>
  <data key="d1">concept</data>
  <data key="d2">방사선과 원자핵의 상호작용으로 일어나는 현상.</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522942</data>
  <data key="d6"></data>
</node>
<node id="전리방사선">
  <data key="d0">전리방사선</data>
  <data key="d1">concept</data>
  <data key="d2">충돌에 의하여 물질을 이온화시키는 방사선.</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522942</data>
  <data key="d6"></data>
</node>
<node id="직접전리방사선">
  <data key="d0">직접전리방사선</data>
  <data key="d1">concept</data>
  <data key="d2">원자와 충돌하여 그 원자를 전리시킬 수 있는 에너지를 갖는 하전 입자 (α, β, 양성자).</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522942</data>
  <data key="d6"></data>
</node>
<node id="간접전리방사선">
  <data key="d0">간접전리방사선</data>
  <data key="d1">concept</data>
  <data key="d2">원자와 충돌하여 전리나 핵의 변화를 가져올 수 있는 비하전 입자 (X, γ, 중성자).</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522942</data>
  <data key="d6"></data>
</node>
<node id="비전리방사선">
  <data key="d0">비전리방사선</data>
  <data key="d1">concept</data>
  <data key="d2">물질과 상호작용하여 전자를 방출하지 않고 에너지를 전달하는 초음파, 자력선으로서 전리능력이 없는 방사선.</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522942</data>
  <data key="d6"></data>
</node>
<node id="여기(Excitation)">
  <data key="d0">여기(Excitation)</data>
  <data key="d1">concept</data>
  <data key="d2">원자의 궤도전자가 에너지를 흡수하여 안정된 기저상태에서 에너지가 높은 상태로 옮겨가는 것.</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="전리(Ionization)">
  <data key="d0">전리(Ionization)</data>
  <data key="d1">concept</data>
  <data key="d2">에너지를 흡수하여 궤도전자가 원자핵의 구속력으로부터 완전히 벗어나는 것.</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="방사성">
  <data key="d0">방사성</data>
  <data key="d1">concept</data>
  <data key="d2">알파선, 베타선, 감마선 등의 방사선이 원자핵으로부터 자연적으로 방출하는 성질.</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="방사능(Radioactivity)">
  <data key="d0">방사능(Radioactivity)</data>
  <data key="d1">concept</data>
  <data key="d2">방사성 물질이 보유하고 있는 고유한 능력, 붕괴율.</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="방사선+원자">
  <data key="d0">방사선+원자</data>
  <data key="d1">other</data>
  <data key="d2">방사선이 원자와 상호작용하는 것을 의미함.</data>
  <data key="d3">chunk-aba8bf30078b2233792d56a3c43c08ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="E+(양전자)">
  <data key="d0">E+(양전자)</data>
  <data key="d1">data</data>
  <data key="d2">E+(양전자)는 질량수 불변, 원자번호 1 감소시키는 특징을 가진다.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="핵">
  <data key="d0">핵</data>
  <data key="d1">naturalobject</data>
  <data key="d2">핵은 불안정하여 붕괴를 일으키고, 에너지 준위 변화를 겪을 수 있다.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="궤도전자">
  <data key="d0">궤도전자</data>
  <data key="d1">data</data>
  <data key="d2">궤도전자는 핵내의 양성자에 포획되어 중성자로 변환되거나, 내부 전환 과정에서 방출될 수 있다. 주로 K각 전자가 관련된다.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="γ-Decay">
  <data key="d0">γ-Decay</data>
  <data key="d1">method</data>
  <data key="d2">γ-decay(γ방출)는 α 또는 β 붕괴 후 핵 에너지 준위가 높을 때(여기상태) 안정시키기 위하여(기저상태) 방출되는 에너지이다.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="광자">
  <data key="d0">광자</data>
  <data key="d1">naturalobject</data>
  <data key="d2">광자는 γ-decay에서 방출되는 전자파의 본질이다.&lt;SEP&gt;광자 refers to a photon.&lt;SEP&gt;광자는 0.511MeV의 에너지를 갖는 두 개의 입자로, 서로 180° 반대 방향으로 방사된다.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e&lt;SEP&gt;chunk-c6c70af745f8587837b4afa84c640794&lt;SEP&gt;chunk-130264f031a5f67121c20eb9f791ffb6</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775523279</data>
  <data key="d6"></data>
</node>
<node id="γ-선">
  <data key="d0">γ-선</data>
  <data key="d1">content</data>
  <data key="d2">γ-선은 γ-전이 과정에서 방출되는 광자이다.&lt;SEP&gt;γ-선 refers to gamma rays.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e&lt;SEP&gt;chunk-c6c70af745f8587837b4afa84c640794</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522975</data>
  <data key="d6"></data>
</node>
<node id="핵이성체전이">
  <data key="d0">핵이성체전이</data>
  <data key="d1">method</data>
  <data key="d2">핵이성체전이(Isometric transition : IT)는 원자핵 붕괴 이후 원자핵이 준안정상태(metastable)에 있는 경우 단시간 내에 γ-선을 방출하거나 내부전환에 의해 안정상태가 되는 현상 또는 방식이다.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="준안정상태">
  <data key="d0">준안정상태</data>
  <data key="d1">concept</data>
  <data key="d2">준안정상태(metastable)는 핵이성체전이에서 원자핵이 갖는 에너지 준위가 높은 상태를 의미한다.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="핵이성체">
  <data key="d0">핵이성체</data>
  <data key="d1">data</data>
  <data key="d2">핵이성체(isomer)는 준안정상태에 머물러 있는 핵을 의미한다.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="내부전환">
  <data key="d0">내부전환</data>
  <data key="d1">method</data>
  <data key="d2">내부전환(Internal Conversion ; IC)은 불안정한 원자핵이 반드시 γ-선으로만 방출되는 것이 아니고 궤도전자에 그 에너지를 주어 궤도전자를 방출하는 현상이다.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522943</data>
  <data key="d6"></data>
</node>
<node id="내부전환전자">
  <data key="d0">내부전환전자</data>
  <data key="d1">data</data>
  <data key="d2">내부전환전자(Internal Conversion Electron) 또는 전환전자(conversion electron : CE)는 내부전환 과정에서 방출되는 전자를 의미한다.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522944</data>
  <data key="d6"></data>
</node>
<node id="고전산란">
  <data key="d0">고전산란</data>
  <data key="d1">method</data>
  <data key="d2">고전산란은 언급된 페이지 61-63에서 다루어지는 현상이다.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522944</data>
  <data key="d6"></data>
</node>
<node id="Electron Capture">
  <data key="d0">Electron Capture</data>
  <data key="d1">method</data>
  <data key="d2">Electron Capture (EC, K-capture) occurs in nuclei deficient in neutrons and involves the capture of an orbital electron (usually from the K-shell) by a proton in the nucleus, transforming it into a neutron and emitting a neutrino.</data>
  <data key="d3">chunk-734454390e5e52b722069b53101aa55e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522944</data>
  <data key="d6"></data>
</node>
<node id="방사성물질">
  <data key="d0">방사성물질</data>
  <data key="d3">chunk-ad2bbaf70d414921fce8a89c3f0030d8</data>
  <data key="d2">강도는 방사성 물질의 양과 관련이 있다.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522944</data>
  <data key="d6"></data>
</node>
<node id="99mTc-Gh">
  <data key="d0">99mTc-Gh</data>
  <data key="d1">chemicalcompound</data>
  <data key="d2">99mTc-Gh is associated with renogram tests and can cause adverse reactions such as vasovagal response and allergic reactions.</data>
  <data key="d3">chunk-9d83407b553bdad56b98cf8fd5be64bc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522968</data>
  <data key="d6"></data>
</node>
<node id="Vasovagal Response">
  <data key="d0">Vasovagal Response</data>
  <data key="d1">concept</data>
  <data key="d2">Vasovagal response includes symptoms like nausea, vomiting, and dizziness immediately after injection.</data>
  <data key="d3">chunk-9d83407b553bdad56b98cf8fd5be64bc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522968</data>
  <data key="d6"></data>
</node>
<node id="Allergic Reaction">
  <data key="d0">Allergic Reaction</data>
  <data key="d1">concept</data>
  <data key="d2">Allergic reactions are potential adverse effects of certain medical procedures, as indicated in the text.</data>
  <data key="d3">chunk-9d83407b553bdad56b98cf8fd5be64bc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522968</data>
  <data key="d6"></data>
</node>
<node id="Radiography">
  <data key="d0">Radiography</data>
  <data key="d1">method</data>
  <data key="d2">Radiography is a method that involves using radiation for imaging.</data>
  <data key="d3">chunk-9d83407b553bdad56b98cf8fd5be64bc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522969</data>
  <data key="d6"></data>
</node>
<node id="99Mo–99mTc Generator">
  <data key="d0">99Mo–99mTc Generator</data>
  <data key="d1">artifact</data>
  <data key="d2">The 99Mo–99mTc generator produces 99mTcO4‾, which has a half-life of 6 hours.&lt;SEP&gt;99Mo–99mTc Generator generates 99mTc by adsorbing 99Mo on an alumina column.</data>
  <data key="d3">chunk-9d83407b553bdad56b98cf8fd5be64bc&lt;SEP&gt;chunk-924d4e084e2a6643308b6bc76af06895</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775523008</data>
  <data key="d6"></data>
</node>
<node id="99mTcO4‾">
  <data key="d0">99mTcO4‾</data>
  <data key="d1">chemicalcompound</data>
  <data key="d2">99mTcO4‾ has a half-life of 6 hours and is easily used in medical applications.</data>
  <data key="d3">chunk-9d83407b553bdad56b98cf8fd5be64bc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522969</data>
  <data key="d6"></data>
</node>
<node id="81Rb–81mKr Generator">
  <data key="d0">81Rb–81mKr Generator</data>
  <data key="d1">artifact</data>
  <data key="d2">The 81Rb–81mKr generator produces 81mKr, which has a half-life of 13 seconds.</data>
  <data key="d3">chunk-9d83407b553bdad56b98cf8fd5be64bc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522969</data>
  <data key="d6"></data>
</node>
<node id="81mKr">
  <data key="d0">81mKr</data>
  <data key="d1">content</data>
  <data key="d2">81mKr has a very short half-life of 13 seconds, limiting its clinical applications despite its low contamination risk.&lt;SEP&gt;81mKr은 크립톤의 방사성 동위원소이다.&lt;SEP&gt;An isotope with a specific energy level.</data>
  <data key="d3">chunk-9d83407b553bdad56b98cf8fd5be64bc&lt;SEP&gt;chunk-fd28894fc7b2a8aeb26f735075d67fb8&lt;SEP&gt;chunk-73fd9633bf193d21c88e0cf35c08d9fa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775523204</data>
  <data key="d6"></data>
</node>
<node id="Radioimmunoassay">
  <data key="d0">Radioimmunoassay</data>
  <data key="d1">method</data>
  <data key="d2">Radioimmunoassay (RIA) is an in-vitro test method.</data>
  <data key="d3">chunk-9d83407b553bdad56b98cf8fd5be64bc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522969</data>
  <data key="d6"></data>
</node>
<node id="Alpha Particle">
  <data key="d0">Alpha Particle</data>
  <data key="d1">naturalobject</data>
  <data key="d2">Alpha particles have a short penetration range (0.06~0.16 mm) in the body and are generally not used for in-vivo applications.</data>
  <data key="d3">chunk-9d83407b553bdad56b98cf8fd5be64bc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522969</data>
  <data key="d6"></data>
</node>
<node id="Beta Particle">
  <data key="d0">Beta Particle</data>
  <data key="d1">naturalobject</data>
  <data key="d2">Beta particles have a limited range in water and are used in liquid scintillation counting for isotopes like 14C and 3H.</data>
  <data key="d3">chunk-9d83407b553bdad56b98cf8fd5be64bc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775522969</data>
  <data key="d6"></data>
</node>
<node id="14C">
  <data key="d0">14C</data>
  <data key="d1">data</data>
  <data key="d2">14C is used in liquid scintillation counting.&lt;SEP&gt;14C is a radioactive isotope used to label steroid hormones, emitting low-energy β-rays.&lt;SEP&gt;14C is an isotope used in 체외진단용방사성의약품.&lt;SEP&gt;14C has a half-life of 5,730 years and emits beta radiation of 0.156, used for labeling organic compounds.&lt;SEP&gt;14C 핵종은 액체섬광을 통해 측정할 수 있다.</data>
  <data key="d3">chunk-9d83407b553bdad56b98cf8fd5be64bc&lt;SEP&gt;chunk-06409f405ed68573d707ceaadba57801&lt;SEP&gt;chunk-924d4e084e2a6643308b6bc76af06895&lt;SEP&gt;chunk-01aeb670194fbaa7323582a61264ce3a&lt;SEP&gt;chunk-78dbaba6777799b28327851a2d931cc2</data>
  <data key="d4">unknown_source</data>
