  <data key="d5">1775523284</data>
  <data key="d6"></data>
</node>
<node id="Attenuation Profiles">
  <data key="d0">Attenuation Profiles</data>
  <data key="d1">data</data>
  <data key="d2">Raw data에서 Sequence of attenuation profiles를 거쳐 Full rotation 후 CT raw data를 얻음.</data>
