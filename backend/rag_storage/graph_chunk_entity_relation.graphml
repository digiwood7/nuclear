  <data key="d6"></data>
</node>
<node id="Resolution">
  <data key="d0">Resolution</data>
  <data key="d1">concept</data>
  <data key="d2">Resolution refers to the ability to detect the distribution of radioisotopes (RI) in the human body in detail; it is the ability to separate two points.&lt;SEP&gt;Resolution refers to the clarity and detail of the energy analysis.</data>
  <data key="d3">chunk-08708d5929cf7059523d87243b280f2c&lt;SEP&gt;chunk-03574e2708590c1fbd812aab77b1c581</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775523227</data>
  <data key="d6"></data>
</node>
<node id="Sensitivity">
  <data key="d0">Sensitivity</data>
  <data key="d1">concept</data>
  <data key="d2">Sensitivity is the ratio of gamma rays emitted from RI that reach and are detected by the detector.</data>
  <data key="d3">chunk-08708d5929cf7059523d87243b280f2c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775523200</data>
