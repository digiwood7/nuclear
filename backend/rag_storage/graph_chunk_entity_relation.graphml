  <data key="d0">MTF</data>
  <data key="d1">method</data>
  <data key="d2">MTF (modulation transfer function) is used in digital imaging for assessing spatial resolution.</data>
  <data key="d3">chunk-435f46f7df27683a6f082e9ae451704b</data>
  <data key="d4">unknown_source</data>
