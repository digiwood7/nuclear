  <data key="d0">GEMINI TF (PHILIPS)</data>
  <data key="d1">artifact</data>
  <data key="d2">GEMINI TF (PHILIPS)는 GSO를 사용하는 장비이다.</data>
  <data key="d3">chunk-50349fd89c39a44e7081da426038f848</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775523306</data>
  <data key="d6"></data>
</node>
<node id="Discovery STE (GE Healthcare)">
